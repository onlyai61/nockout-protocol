# Nockout Protocol shared environment template
# Copy to .env.local and fill values from Supabase project settings.

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_do_not_commit_real_value
SUPABASE_PROJECT_REF=your_project_ref

# Google OAuth for Supabase Auth
GOOGLE_OAUTH_CLIENT_ID=956756213946-vsvlk574kejn5oi3klgk7r2jfq8uk45i.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_do_not_commit_real_value

# Kakao OAuth for Supabase Auth
KAKAO_OAUTH_CLIENT_ID=your_kakao_rest_api_key
KAKAO_OAUTH_CLIENT_SECRET=your_kakao_client_secret_do_not_commit_real_value

# Apple OAuth for Supabase Auth
APPLE_OAUTH_CLIENT_ID=your_apple_service_id
APPLE_OAUTH_CLIENT_SECRET=your_apple_client_secret_do_not_commit_real_value

# App
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
